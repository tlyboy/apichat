{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ApiChat",
  "version": "0.1.0",
  "identifier": "com.tlyboy.apichat",
  "build": {
    "beforeDevCommand": "cd src-tauri/binaries/apichat-mcp && bun install --frozen-lockfile && bun run build && cd ../../.. && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd src-tauri/binaries/apichat-mcp && bun install --frozen-lockfile && bun run build && cd ../../.. && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ApiChat",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/apichat-mcp"],
    "createUpdaterArtifacts": "v2Compatible"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tlyboy/apichat/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNBQjQzM0E0N0M2NTc0M0IKUldRN2RHVjhwRE8wT2svVW5PLy91aXp0NTJGaFoyZGdVSGFYZHE3ZENHYkQ0c1BjT1VReGhVcEsK"
    }
  }
}
