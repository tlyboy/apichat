{
  "name": "apichat-mcp",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:mac-arm64": "bun build ./src/index.ts --compile --minify --target=bun-darwin-arm64 --outfile ../apichat-mcp-aarch64-apple-darwin",
    "build:mac-x64": "bun build ./src/index.ts --compile --minify --target=bun-darwin-x64 --outfile ../apichat-mcp-x86_64-apple-darwin",
    "build:win": "bun build ./src/index.ts --compile --minify --target=bun-windows-x64 --outfile ../apichat-mcp-x86_64-pc-windows-msvc.exe",
    "build:linux": "bun build ./src/index.ts --compile --minify --target=bun-linux-x64 --outfile ../apichat-mcp-x86_64-unknown-linux-gnu"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "yaml": "^2.8.2"
  }
}
